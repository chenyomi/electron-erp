{
  "name": "donghao-ledger",
  "version": "1.0.10",
  "description": "温州东昊汽车配件有限公司 账务管理系统",
  "author": "chenyomi <408550179@qq.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "dev:clean": "electron-vite build && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3,sharp",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,sharp",
    "icons": "node scripts/generate-app-icons.cjs",
    "installer-assets": "node scripts/generate-installer-assets.cjs",
    "assets": "pnpm icons && pnpm installer-assets",
    "import:ledger": "ELECTRON_RUN_AS_NODE=1 electron scripts/import-ledger.cjs",
    "package:mac": "pnpm assets && electron-builder --mac --arm64 --x64",
    "package:win": "pnpm assets && electron-builder --win --x64"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "better-sqlite3": "^9.6.0",
    "detect-libc": "^2.1.2",
    "echarts": "^6.1.0",
    "jszip": "^3.10.1",
    "semver": "^7.7.2",
    "sharp": "^0.35.1",
    "vue": "^3.5.38",
    "vuetify": "^4.1.1",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^3.7.2",
    "@fontsource/noto-sans-sc": "^5.2.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.43",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "opentype.js": "1.3.4",
    "prebuild-install": "^7.1.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "build": {
    "publish": null,
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/detect-libc/**",
      "**/node_modules/semver/**"
    ],
    "appId": "com.donghao.ledger",
    "productName": "东昊账务",
    "copyright": "Copyright © chenyomi",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.finance",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "东昊账务 ${version}",
      "background": "resources/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 144,
          "y": 180,
          "type": "file"
        },
        {
          "x": 396,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "东昊账务",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeader": "resources/installer-header.bmp",
      "installerSidebar": "resources/installer-sidebar.bmp",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "displayLanguageSelector": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "out/**/*",
      "resources/icon.icns",
      "resources/icon.ico",
      "resources/icon.png"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "sharp"
    ],
    "overrides": {
      "@electron/node-gyp": "10.2.0-electron.1"
    }
  }
}
